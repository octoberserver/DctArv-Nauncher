    <property name="styleSheet">
     <string notr="true">#scrollArea {
    background-color: transparent; /* 徹底透明 */
    border-radius: 40px; 
    border: none; 
}

#scrollAreaWidgetContents {
    background: transparent;
    border: none;
}

QLabel {
    color: 	#000000;
    font-family: &quot;Microsoft JhengHei&quot;;
}

#background {
/* 從左上到右下的微弱漸層 */
    background-color: qlineargradient(
        x1: 0, y1: 0, x2: 1, y2: 1,
        stop: 0 rgba(255, 255, 255, 0.12), 
        stop: 0.5 rgba(255, 255, 255, 0.05), 
        stop: 1 rgba(255, 255, 255, 0.1)
    );
    border-radius: 15px;
    border: 1px solid rgba(255, 255, 255, 0.1);

}

#background:hover {
	background-color: rgba(255, 255, 255, 0.15);
    border: 1px solid rgba(189, 147, 249, 0.5); /* 移上去時邊框變紫色微光 */
}

#annou {
	color: #ffffff;
	font-size:20px;
}

#date {
    color: #6272a4; 
    font-size: 11px;
}

#pushButton {
    color: #bd93f9;
    background: transparent;
    font-weight: bold;
    border: none;
}

#pushButton:hover {
    color: #ff79c6;
}</string>
