    <property name="styleSheet">
     <string notr="true">#photo {
    /* 1. 設定背景圖片路徑 (開頭一定要有冒號) */
   border-image: url(:/a);

    /* 2. 設定圖片不重複 */
    background-repeat: no-repeat;

    /* 3. 設定圖片置中 */
    background-position: center;

    /* 4. 設定圓角 (這就是你要的現代感) */
    border-radius: 40px;

    /* 5. 選擇性：加上邊框讓卡片更明顯 */
    border: 1px solid #2d2f45;
}</string>
